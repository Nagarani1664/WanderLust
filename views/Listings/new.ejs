<% layout("layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2" >

<h3>Please enter Listing Details:</h3>
<br>
<br>
<form method="post" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

<div class="mb-3">
<label class="form-label">Title</label>
<input type="text" name="listing[title]" class="form-control" placeholder="enter catchy title" required>
 <div class="valid-feedback">Title looks good</div>
<div class="invalid-feedback">Title is required</div>
</div>

<div class="mb-3">
<label class="form-label">Description</label>
<input type="text" name="listing[description]" class="form-control" placeholder="description" required>
 <div class="valid-feedback">Nice Description</div>
<div class="invalid-feedback">Enter short Description </div>
</div>
<div class="mb-3">
<label for="category">Choose a Category:</label>
<select id="category" name="listing[category]" required>
  <option value="">--Select--</option>
  <option value="Mountains">Mountains</option>
  <option value="Pools">Pools</option>
  <option value="Farm">Farm</option>
  <option value="Snow">Snow</option>
  <option value="Castles">Castles</option>
  <option value="Camping">Camping</option>
</select>

</div>
<div class="mb-3">
<label class="form-label">Image</label>
<input type="file" name="listing[image]" class="form-control" placeholder="Please upload image" required>
</div>
<div class="row">
<div class="mb-3 col-md-4" >
<label class="form-label">Price</label>
<input type="number" name="listing[price]" class="form-control" placeholder="800" required >
 <div class="valid-feedback">Please enter valid price</div>
<div class="invalid-feedback">Invalid price</div>
</div>

<div class="mb-3 col-md-8">
<label class="form-label">Country</label>
<input type="text" name="listing[country]" class="form-control" placeholder="India"  required>
 <div class="valid-feedback"></div>
<div class="invalid-feedback">Enter valid country</div>
</div>
</div>

<div class="mb-3">
<label class="form-label">Location</label>
<input type="text" name="listing[location]" class="form-control" placeholder="Rajasthan India" required>
 <div class="valid-feedback"></div>
<div class="invalid-feedback">Enter valid location</div>
</div>
<br>
<br>

<button type="submit" class="btn btn-primary add-btn mt-3">Submit</button>

</form>
</div>
</div>