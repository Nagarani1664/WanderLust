<% layout("layouts/boilerplate") %>


 <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 margin-top-3">
  <% for(let listing of user.wishlist){ %>

    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="listing-card">

          <img src="<%= listing.image.url %>" 
               class="card-img-top" 
               style="height: 20rem;" />
               
               <div class="card-body">
                 <p class="card-text">
                   <b><%= listing.title %></b><br>
                   ⭐ <%= listing.avgrating ? listing.avgrating.toFixed(1) : "New" %>
                   <br>
              &#8377;
              <%= listing.price.toLocaleString("en-IN") %>/night
              <i class="tax-info">&nbsp; &nbsp; +18%GST</i>
            </p>
          </div>
          <div>
          
         </div>
        </div>
      </a>
      <form action="/listings/wishlist/<%=listing._id%>?_method=DELETE" method="post">
          <button>Remove from List</button>
      </form>
      <div>
      </div>
      <div>
      </div>
    </div>

  <% } %>
</div>